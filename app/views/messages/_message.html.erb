<% viewer = local_assigns[:user] %>
<% is_current_user = viewer.present? && message.user_id == viewer.id %>
<div class="mb-3 <%= is_current_user ? 'message-row-right' : 'message-row-left' %>">
  <div class="message-container">
    <div class="small mb-1 <%= is_current_user ? 'text-end' : 'text-start' %>">
      <strong><%= is_current_user ? 'You' : message.user.full_name %></strong>
      <span class="text-muted ms-2"><%= message.created_at.strftime('%b %-d, %H:%M') %></span>
    </div>
    <div class="p-2 rounded message-bubble <%= is_current_user ? 'message-bubble-current-user ms-auto' : 'bg-light me-auto' %>">
      <%= message.content %>
    </div>
  </div>
</div>
