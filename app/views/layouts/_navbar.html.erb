<nav class="navbar navbar-dark navbar-expand-lg">
  <div class="container-fluid nav-container">
    <%= link_to "Connected", feed_path, class: "navbar-brand me-5" %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <%= link_to "Home", feed_path, class: "nav-link #{current_class?(feed_path)}" %>
        </li>
        <li class="nav-item">
          <%= link_to conversations_path, class: "nav-link #{current_class?(conversations_path)}" do %>
            Conversations
            <% if current_user.unread_messages_count > 0 %>
              <span class="badge bg-danger rounded-pill ms-1"><%= current_user.unread_messages_count %></span>
            <% end %>
          <% end %>
        </li>
        <li class="nav-item">
          <%= link_to connections_path, class: "nav-link #{current_class?(connections_path)}" do %>
            Connections
            <% if current_user.pending_connections_count > 0 %>
              <span class="badge bg-danger rounded-pill ms-1"><%= current_user.pending_connections_count %></span>
            <% end %>
          <% end %>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle <%= current_page?(posts_path) || current_page?(edit_user_registration_path) ? 'active' : '' %>" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <% if user_signed_in? %>
              <%= current_user.full_name %>
            <% end %>
          </a>
          <ul class="dropdown-menu">
            <li><%= link_to "Your profile", posts_path, class: "dropdown-item" %></li>
            <li><hr class="dropdown-divider"></li>
            <li><%= button_to 'Log out', destroy_user_session_path, method: :delete, class: "dropdown-item text-danger" %></li>
          </ul>
        </li>
      </ul>
      <%= render 'search/form' %>
    </div>
  </div>
</nav>
