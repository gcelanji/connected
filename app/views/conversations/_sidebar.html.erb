<div class="col-12 col-md-4">
  <div class="bg-white shadow rounded p-2">
    <% if @conversations.empty? %>
      <p class="mb-0 px-2 py-3 text-muted">No conversations yet.</p>
    <% else %>
      <ul class="list-group list-group-flush">
        <% @conversations.each do |conversation| %>
          <% is_selected = defined?(@conversation) && @conversation&.id == conversation.id %>
          <% other_users = conversation.users.reject { |u| u.id == current_user.id } %>
          <% title = conversation.name.presence || other_users.map(&:full_name).join(', ').presence || 'Conversation' %>
          <% last_message = conversation.messages.sort_by { |m| m.created_at || Time.at(0) }.last %>

          <li class="list-group-item px-2 py-3 <%= 'bg-light' if is_selected %>">
            <div class="d-flex justify-content-between align-items-start">
              <%= link_to conversation_path(conversation), class: 'text-decoration-none text-dark flex-grow-1' do %>
                <div class="fw-semibold"><%= title %></div>
                <% if last_message.present? %>
                  <div class="small text-muted text-truncate"><%= last_message.content %></div>
                <% else %>
                  <div class="small text-muted">No messages yet</div>
                <% end %>
              <% end %>
              <%= link_to conversation_path(conversation),
                          method: :delete,
                          data: { confirm: "Are you sure you want to delete this conversation?" },
                          class: "ms-2" do %>
                <%= image_tag("icons8-remove-96.png", options = { class: "action-image-20", title: "Delete conversation" }) %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
