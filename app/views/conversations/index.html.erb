<h5 class="app-container mx-auto mt-5">Conversations</h5>

<div class="app-container mx-auto mt-3">
  <div class="row g-3">
    <div class="col-12 col-md-4">
      <div class="bg-white shadow rounded p-2">
        <% if @conversations.empty? %>
          <p class="mb-0 px-2 py-3 text-muted">No conversations yet.</p>
        <% else %>
          <ul class="list-group list-group-flush">
            <% @conversations.each do |conversation| %>
              <% title = conversation.name.presence || conversation.users.where.not(id: current_user.id).map(&:full_name).join(', ').presence || 'Conversation' %>
              <% last_message = conversation.messages.order(created_at: :desc).first %>
              <% unread_count = conversation.messages.where(read: false).where.not(user_id: current_user.id).count %>

              <li class="list-group-item px-2 py-3">
                <div class="d-flex justify-content-between align-items-start">
                  <%= link_to conversation_path(conversation), class: 'text-decoration-none text-dark flex-grow-1' do %>
                    <div class="<%= unread_count.positive? ? 'fw-bold' : 'fw-semibold' %>"><%= title %></div>
                    <% if last_message.present? %>
                      <div class="small text-truncate <%= unread_count.positive? ? 'text-dark fw-semibold' : 'text-muted' %>"><%= last_message.content %></div>
                    <% else %>
                      <div class="small text-muted">No messages yet</div>
                    <% end %>
                  <% end %>
                  <%= link_to conversation_path(conversation),
                              method: :delete,
                              data: { confirm: "Are you sure you want to delete this conversation?" },
                              class: "ms-2" do %>
                    <%= image_tag("icons8-remove-96.png", options = { class: "action-image-20", title: "Delete conversation" }) %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </div>

    <div class="col-12 col-md-8">
      <div class="bg-white shadow rounded p-3">
        <h6 class="mb-3">Start a Conversation</h6>
        <p class="text-muted">Select a conversation from the left sidebar to view messages, or click the "Message" button on a connection below to start messaging.</p>
        
        <% if @connections.empty? %>
          <p class="text-muted mb-0">You don't have any connections yet. <%= link_to "Find connections", connections_path %> to start messaging.</p>
        <% else %>
          <div class="list-group">
            <% @connections.each do |connection| %>
              <div class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= connection.full_name %></span>
                <% conversation = Conversation.between([current_user.id, connection.id]) %>

                <% if conversation %>
                  <%= link_to "Message", conversation_path(conversation), 
                      class: 'btn btn-sm btn-main-custom' %>
                <% else %>
                  <%= link_to "Message", conversations_path(user_id: connection.id), 
                      method: :post, class: 'btn btn-sm btn-main-custom' %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
